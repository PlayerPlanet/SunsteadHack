{
  "family": "${TASK_FAMILY_NAME_FULL_RUN}",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "${TASK_CPU}",
  "memory": "${TASK_MEMORY}",
  "executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/${TASK_EXECUTION_ROLE_NAME}",
  "taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/${TASK_ROLE_NAME}",
  "containerDefinitions": [
    {
      "name": "full-run",
      "image": "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO_NAME}:full-run-${ECR_IMAGE_TAG}",
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/${TASK_FAMILY_NAME_FULL_RUN}",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "full-run"
        }
      },
      "secrets": [
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRET_ANTHROPIC_API_KEY_NAME}-*"
        },
        {
          "name": "DB_DSN",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRET_DB_DSN_NAME}-*"
        }
      ],
      "environment": [
        {
          "name": "TASK_ID",
          "value": "placeholder-task-id"
        },
        {
          "name": "MODEL",
          "value": "claude-haiku-4-5-20251001"
        },
        {
          "name": "ITERATIONS",
          "value": "1"
        }
      ]
    }
  ]
}
