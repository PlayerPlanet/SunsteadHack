# AWS Deployment Configuration for SunsteadHack
# Copy to config.env and customize for your environment.
# NEVER commit real secrets; always use env vars at deploy time.

# ---- AWS Account & Region -----------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ---- ECR (Elastic Container Registry) -----------------------------------
ECR_REPO_NAME=sunsteadhack
ECR_IMAGE_TAG=proposer-phase0
# Full ECR URI will be: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO_NAME}:${ECR_IMAGE_TAG}

# ---- ECS (Elastic Container Service) ------------------------------------
ECS_CLUSTER_NAME=story-e-cluster
TASK_FAMILY_NAME=sunsteadhack-proposer
TASK_FAMILY_NAME_FULL_RUN=sunsteadhack-full-run
TASK_ROLE_NAME=sunsteadhack-task-role
TASK_EXECUTION_ROLE_NAME=sunsteadhack-task-execution-role

# Fargate requires CPU/memory pairs: 256/.5GB, 512/1GB, 512/2GB, 512/3GB, 512/4GB, 1024/2GB-8GB, 2048/4GB-16GB, 4096/8GB-30GB
TASK_CPU=512
TASK_MEMORY=1024

# ---- VPC & Network (must already exist) ----------------------------------
# Public subnets are fine: tasks run with assignPublicIp=ENABLED (set in
# launch_run.py / 50-smoke.sh) so they get egress without a NAT Gateway; the
# egress-only SG blocks all inbound. Use private subnets + NAT only if you flip
# assignPublicIp back to DISABLED.
VPC_ID=vpc-abc123
SUBNET_ID_1=subnet-abc123
SUBNET_ID_2=subnet-def456
SECURITY_GROUP_ID=sg-abc123
# DB egress port. Aiven Postgres uses a NON-standard port (e.g. 11244), NOT 5432.
# 30-network.sh opens this port outbound; check your service's connection info.
DB_PORT=5432

# ---- Secrets Manager (will be created/updated) ---------------------------
# These secrets will be created in AWS Secrets Manager if they don't exist.
# Values are read from environment variables at deploy time (never stored here).
SECRET_ANTHROPIC_API_KEY_NAME=sunsteadhack/anthropic-api-key
SECRET_DB_DSN_NAME=sunsteadhack/db-dsn

# ---- CloudWatch Logs (auto-created by setup scripts) --------------------
CLOUDWATCH_LOG_GROUP=/ecs/${TASK_FAMILY_NAME}
CLOUDWATCH_LOG_STREAM=proposer-$(date +%Y-%m-%d)

# ---- Database (read-only Aiven or RDS replica) --------------------------
# Example: postgresql://researcher_ro:pass@db-abc123.aivencloud.com:5432/postgres
# This will be injected into ECS task as a secret, NOT as a plaintext env var.
# At deploy time, set: export DB_DSN="postgresql://researcher_ro:pass@..."
# The setup script will NOT echo it.
DB_DSN_PLACEHOLDER="set via environment variable DB_DSN at deploy time"

# ---- Docker Build (for proposer container) ------------------------------
PROPOSER_CONTAINER_DIR=../../proposer-container
DOCKER_BUILD_CONTEXT=${PROPOSER_CONTAINER_DIR}
