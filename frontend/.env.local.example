# Dashboard auth + control-plane wiring. Copy to .env.local and fill in.
# Values come from scripts/setup_cognito_dashboard.sh and the deployed runtime.

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Amazon Cognito (the IdP AgentCore validates against) ---
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_8d4jfqwov
COGNITO_CLIENT_ID=5n4dhk9urmv04rtccq0cgefluv
# from the gitignored dashboard_client.secret written by setup_cognito_dashboard.sh
COGNITO_CLIENT_SECRET=

# --- Control-plane runtime (privileged actions go here, with the user's bearer) ---
# The AgentCore invocation URL (same as plugin/.mcp.remote.json).
AGENT_RUNTIME_URL=https://bedrock-agentcore.us-east-1.amazonaws.com/runtimes/arn%3Aaws%3Abedrock-agentcore%3Aus-east-1%3A528081867249%3Aruntime%2Fsunsteadcontrol_sunstead_control-u9zi87DjdX/invocations?qualifier=DEFAULT

# --- Reads (charts/lists query Aiven directly; unchanged from before) ---
# POSTGRES_URL=postgres://...:.../sunstead_control?sslmode=require
